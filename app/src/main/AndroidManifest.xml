<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos requeridos para Samsung Health SDK -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    
    <!-- Foreground service permissions for persistent watch communication -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Queries declaration para Android 11+ - Permite encontrar y comunicarse con Samsung Health -->
    <!-- Incluimos ambos package names posibles para compatibilidad con diferentes versiones -->
    <queries>
        <package android:name="com.samsung.android.app.shealth" />
        <package android:name="com.sec.android.app.shealth" />
        <package android:name="com.samsung.android.samsunghealth" />
        <package android:name="com.google.android.wearable.app" />
        <!-- OAuth browsers -->
        <package android:name="com.android.chrome" />
        <package android:name="com.chrome.beta" />
        <package android:name="com.chrome.dev" />
        <package android:name="com.google.android.apps.chrome" />
        <!-- Samsung Health Deep Links -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="shealth" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="samsunghealthmonitor" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".HealthDiaryApp"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.MyApplication">

        <activity
            android:name=".activity.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait" />
        
        <!-- OAuth Redirect Handler Activity -->
        <activity
            android:name=".oauth.OAuthRedirectActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="${appAuthRedirectScheme}"
                    android:host="oauth2redirect" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".activity.HealthMainActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.Splash"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Watch onboarding/pairing screen -->
        <activity
            android:name=".wearable.ui.WatchOnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait" />

        <!-- Role selection screen - shown after login -->
        <activity
            android:name=".activity.RoleSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait" />

        <!-- Family linking screen - for caregivers -->
        <activity
            android:name=".activity.FamilyLinkActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait" />

        <!-- Caregiver pairing screen - enter patient code -->
        <activity
            android:name=".activity.CaregiverPairingActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait" />

        <!-- Patient pairing screen - generate code for caregiver -->
        <activity
            android:name=".activity.PatientPairingActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait" />

        <activity
            android:name=".habit.HabitConfirmationActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait" />

        <receiver
            android:name=".training.TrainingReminderReceiver"
            android:exported="false" />
        <receiver
            android:name=".habit.HabitAlarmReceiver"
            android:exported="false" />
        <activity android:name=".activity.StepActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.HeartRateActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.NutritionActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.SleepActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.ChooseFoodActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.UpdateFoodActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.ExerciseActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.ExerciseLocationActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.SkinTemperatureActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.BloodOxygenActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.ActivitySummaryActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.FloorsClimbedActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.BloodGlucoseActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.BloodPressureActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.BodyCompositionActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.SleepGoalActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.StepsGoalActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.ActiveCaloriesGoalActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.ActiveTimeGoalActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.WaterIntakeActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.WaterIntakeGoalActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.NutritionGoalActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.EnergyScoreActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.UserProfileActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activity.BodyTemperatureActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".workout.ui.WorkoutDebugActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Enable Wear OS Data Layer sync -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />
        
        <meta-data
            android:name="com.google.android.gms.wearable.BIND_LISTENER"
            android:value="true" />

        <service
            android:name=".wearable.PhoneChannelReceiverService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.CHANNEL_EVENT" />
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/stream/sensors/v1" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/state/watch" />
            </intent-filter>
        </service>

        <service
            android:name=".wearable.PhoneWearableService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <service
            android:name=".habit.HabitWearableService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/habit/reminder/done" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/habit/reminder/postpone" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/habit/log" />
            </intent-filter>
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Disable automatic WorkManager initialization since we use Configuration.Provider -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Health Data Receiver - listens for watch health data -->
        <service
            android:name=".wearable.WearableReceiverService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <!-- Health Data Paths (Primary) -->
                <data android:scheme="wear" android:host="*" android:pathPrefix="/health/daily" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/health/hr" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/health/sleep" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/health/steps" />
                <!-- Legacy Paths -->
                <data android:scheme="wear" android:host="*" android:pathPrefix="/sensor_batch" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/handshake_response" />
            </intent-filter>
            <!-- Separate intent-filter for Messages -->
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/sensor_data" />
            </intent-filter>
        </service>
    </application>

</manifest>