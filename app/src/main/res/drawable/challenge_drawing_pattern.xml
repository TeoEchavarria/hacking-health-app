<?xml version="1.0" encoding="utf-8"?>
<!-- Challenge Drawing: Geometric Pattern - Circles and Squares -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <!-- Large center circle -->
    <path
        android:fillColor="#4169E1"
        android:pathData="M100,100 m-50,0 a50,50 0 1,1 100,0 a50,50 0 1,1 -100,0" />
    <!-- Top left square -->
    <path
        android:fillColor="#FF6347"
        android:pathData="M20,20 L20,60 L60,60 L60,20 Z" />
    <!-- Top right triangle -->
    <path
        android:fillColor="#32CD32"
        android:pathData="M160,20 L140,60 L180,60 Z" />
    <!-- Bottom left triangle -->
    <path
        android:fillColor="#FFD700"
        android:pathData="M40,180 L20,140 L60,140 Z" />
    <!-- Bottom right square -->
    <path
        android:fillColor="#9370DB"
        android:pathData="M140,140 L140,180 L180,180 L180,140 Z" />
    <!-- Small center circle -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M100,100 m-20,0 a20,20 0 1,1 40,0 a20,20 0 1,1 -40,0" />
</vector>
