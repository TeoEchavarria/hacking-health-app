<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.samsung.android.health.sdk.sample.healthdiary.viewmodel.BaseHealthDataViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="@dimen/layout_margin">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/metric_icon"
                android:layout_width="@dimen/image_layout_width"
                android:layout_height="@dimen/image_layout_width"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_health_metric" />

            <TextView
                android:id="@+id/metric_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/layout_margin_start"
                android:textColor="@color/text_primary"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/layout_margin_top"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/move_previous_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_move_back" />

            <TextView
                android:id="@+id/date_picker"
                android:layout_width="@dimen/date_tv_width"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@{viewModel.dayStartTimeAsText}"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/date_text_size" />

            <ImageButton
                android:id="@+id/move_next_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_move_next" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/loading_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/layout_margin_top"
            android:visibility='@{viewModel.isLoading ? View.VISIBLE : View.GONE}' />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/metric_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/layout_margin_top"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="@dimen/layout_margin"
            android:text="@string/no_data"
            android:textColor="@color/text_secondary"
            android:textAppearance="?attr/textAppearanceBody1"
            android:visibility="gone" />

    </LinearLayout>
</layout>

